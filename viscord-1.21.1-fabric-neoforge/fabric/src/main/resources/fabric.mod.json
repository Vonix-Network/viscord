{
  "schemaVersion": 1,
  "id": "viscord",
  "version": "${version}",
  "name": "Viscord",
  "description": "Discord Multi-Server Integration for Minecraft - Optimized for multiple servers with embed parsing and anti-loop for webhooks",
  "authors": [
    "Vonix"
  ],
  "contact": {
    "homepage": "https://github.com/vonix-network/viscord",
    "sources": "https://github.com/vonix-network/viscord"
  },
  "license": "MIT",
  "icon": "assets/viscord/icon.png",
  "environment": "*",
  "entrypoints": {
    "server": [
      "network.vonix.viscord.fabric.ViscordFabric"
    ]
  },
  "mixins": [
    "viscord.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "architectury": ">=13.0.8",
    "fabric-api": "*"
  },
  "suggests": {
    "fluxer": "*"
  }
}
